---
import { getCollection } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import { generateBreadcrumbsList } from "@/lib/seo";
import { getSettings } from "@/lib/settings";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();

const settings = await getSettings();
const breadcrumbsPoints = [
  {
    name: "Inicio",
    item: settings.siteUrl || "https://quitargotelebarcelona.es",
  },
  { name: "Blog", item: new URL("/blog/", Astro.site).href },
  { name: post.data.title, item: Astro.url.href },
];
const breadcrumbsSchema = generateBreadcrumbsList(breadcrumbsPoints);
---

<BlogLayout
  title={post.data.title}
  description={post.data.description || ""}
  pubDate={post.data.pubDate ? new Date(post.data.pubDate) : undefined}
  author={post.data.author}
  heroImage={post.data.image}
  tags={post.data.tags}
  category={post.data.category}
  schema={breadcrumbsSchema}
>
  {
    post.data.intro && (
      <p class="lead text-xl text-body font-medium mb-8">{post.data.intro}</p>
    )
  }
  <Content />
</BlogLayout>
