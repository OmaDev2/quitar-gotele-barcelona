---
import { SEO } from "astro-seo";
import type { WithContext, Thing } from "schema-dts";
import { getSettings } from "../lib/settings";

const settings = await getSettings();
const siteName = settings.siteName;

interface Props {
  title: string;
  description: string;
  image?: string;
  schema?: WithContext<Thing> | WithContext<Thing>[];
  noindex?: boolean;
  canonical?: string;
}

const {
  title,
  description,
  image,
  schema,
  noindex = false,
  canonical,
} = Astro.props;

// Generate canonical URL (override if explicitly provided)
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;

// Derivar imagen de OG dinámica basada en el nicho si no hay imagen específica
// Se normaliza el nicho (quitando acentos como la 'é' de gotelé) para evitar errores 404
const normalizedNiche =
  settings.niche
    ?.toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/\s/g, "-") || "default";

const absoluteDefaultOgImage = new URL(
  `/images/og-${normalizedNiche}.png`,
  Astro.site,
).href;

// Asegurar que 'image' sea una URL absoluta si se proporciona, sino usar la por defecto
const ogImage = image
  ? image.startsWith("http")
    ? image
    : new URL(image, Astro.site).href
  : absoluteDefaultOgImage;
---

<SEO
  title={title}
  description={description}
  canonical={canonicalURL}
  openGraph={{
    basic: {
      title,
      type: "website",
      image: ogImage,
      url: canonicalURL,
    },
    optional: {
      description,
      locale: "es_ES",
      siteName: siteName,
    },
  }}
  twitter={{
    card: "summary_large_image",
    title: title,
    description: description,
    image: ogImage,
  }}
  noindex={noindex}
  nofollow={noindex}
/>

{
  schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )
}
