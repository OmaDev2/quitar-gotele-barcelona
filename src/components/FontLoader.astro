---
// Configuración de fuentes y sus pesos para Google Fonts
const fontMap = {
  modern: "family=Inter:wght@400;500;700&family=Oswald:wght@400;500;700",
  robust:
    "family=Barlow+Condensed:wght@400;500;700&family=Roboto:wght@400;500;700",
  elegant: "family=Lato:wght@400;700&family=Playfair+Display:wght@400;600;700",
  friendly: "family=Nunito:wght@400;600;700&family=Open+Sans:wght@400;600",
  tech: "family=Chakra+Petch:wght@400;500;700&family=Exo+2:wght@400;500;700",
  artisan_warm: "family=Merriweather:wght@400;700&family=Lora:wght@400;500;700",
  artisan_natural:
    "family=Crimson+Text:wght@400;600;700&family=Source+Serif+4:wght@400;600",
  artisan_classic:
    "family=Cormorant:wght@400;500;700&family=EB+Garamond:wght@400;500;700",
};

const { pair = "modern" } = Astro.props as { pair: keyof typeof fontMap };
const fontQuery = fontMap[pair] || fontMap.modern;
const googleFontsUrl = `https://fonts.googleapis.com/css2?${fontQuery}&display=swap`;
---

<!-- Carga asíncrona de tipografías para evitar bloqueo de renderizado (LCP/FCP) -->
<link rel="preload" as="style" href={googleFontsUrl} />
<link
  rel="stylesheet"
  href={googleFontsUrl}
  media="print"
  onload="this.media='all'"
/>
<!-- Fallback para carga normal de fuentes si el Javascript está deshabilitado -->
<noscript>
  <link rel="stylesheet" href={googleFontsUrl} />
</noscript>
